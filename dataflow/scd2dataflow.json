{
	"name": "scd2dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText3",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "DelimitedText4",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DelimitedText5",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DelimitedText5",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "sourcederivedColumn"
				},
				{
					"name": "targetderivedColumn"
				},
				{
					"name": "sourceexists1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "targetexists1"
				},
				{
					"name": "targetexists2"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EmployeeID as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          Department as string,",
				"          Email as string,",
				"          Salary as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          EmployeeID as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          Department as string,",
				"          Email as string,",
				"          Salary as string,",
				"          IsActive as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source1 derive(hash = md5(EmployeeID,FirstName,LastName,Department,Email,Salary)) ~> sourcederivedColumn",
				"source2 derive(hash = md5(EmployeeID,FirstName,LastName,Department,Email,Salary)) ~> targetderivedColumn",
				"sourcederivedColumn, targetderivedColumn exists(sourcederivedColumn@hash == targetderivedColumn@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> sourceexists1",
				"sourceexists1 derive(IsActive = 1) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          EmployeeID,",
				"          FirstName,",
				"          LastName,",
				"          Department,",
				"          Email,",
				"          IsActive",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"targetderivedColumn, source1 exists(source2@EmployeeID == source1@EmployeeID,",
				"     negate:false,",
				"     broadcast: 'auto')~> targetexists1",
				"targetexists1, sourcederivedColumn exists(targetderivedColumn@hash == sourcederivedColumn@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> targetexists2",
				"targetexists2 alterRow(updateIf(true())) ~> alterRow1",
				"alterRow1 select(mapColumn(",
				"          EmployeeID,",
				"          FirstName,",
				"          LastName,",
				"          Department,",
				"          Email,",
				"          Salary,",
				"          IsActive",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          EmployeeID as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          Department as string,",
				"          Email as string,",
				"          Salary as string,",
				"          IsActive as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          EmployeeID as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          Department as string,",
				"          Email as string,",
				"          Salary as string,",
				"          IsActive as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink2"
			]
		}
	}
}